# Firebase Web 앱 설정 (Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱)
# 이 파일을 복사해 프로젝트 루트에 `.env` 로 저장하고 값을 채우세요.
# Vite는 `VITE_` 접두사가 있는 변수만 클라이언트에 노출합니다.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 로컬 Vite(5173) — VITE_API_BASE_URL 비울 때 /api·/uploads 를 넘길 백엔드 (기본 http://127.0.0.1:3100)
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3100
